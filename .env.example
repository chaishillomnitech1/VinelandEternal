# ── Deployer ───────────────────────────────────────────────────────────────
# Private key of the wallet that will sign deploy transactions.
# Never commit a real key — add .env to .gitignore.
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ── Mumbai RPC (primary testnet — Polygon) ─────────────────────────────────
# Get a free endpoint from Alchemy, Infura, or use the public RPC
MUMBAI_RPC_URL=https://polygon-mumbai.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ── Sepolia RPC (optional secondary testnet) ───────────────────────────────
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ── Polygonscan (for contract verification on Mumbai) ─────────────────────
POLYGONSCAN_API_KEY=YOUR_POLYGONSCAN_API_KEY

# ── Etherscan (for Sepolia verification) ──────────────────────────────────
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# ── Zakat pool ────────────────────────────────────────────────────────────
# Address that receives the 2.5% zakat on every $MIRROR transfer
ZAKAT_POOL_ADDRESS=0xYOUR_ZAKAT_POOL_ADDRESS

# ── $MIRROR initial supply (whole tokens, no decimals) ────────────────────
MIRROR_INITIAL_SUPPLY=1000000

# ── NFT public mint price in MATIC (e.g. 20 = 20 MATIC) ──────────────────
MINT_PRICE_MATIC=20

# ── Staking reward rate (MIRROR per second per staked NFT, in wei) ────────
# Default: 0.001 MIRROR/s = 86.4 MIRROR/day per NFT
STAKING_REWARD_RATE=1000000000000000

# ── Arweave upload ────────────────────────────────────────────────────────
# Path to your Arweave wallet keyfile (JSON)
ARWEAVE_KEY_PATH=./arweave-wallet.json
