# ── Deployer ───────────────────────────────────────────────────────────────
# Private key of the wallet that will sign deploy transactions.
# Never commit a real key — add .env to .gitignore.
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ── Mumbai RPC (primary testnet — Polygon) ─────────────────────────────────
# Get a free endpoint from Alchemy, Infura, or use the public RPC
MUMBAI_RPC_URL=https://polygon-mumbai.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ── Polygon Mainnet RPC ────────────────────────────────────────────────────
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ── Sepolia RPC (optional secondary testnet) ───────────────────────────────
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ── Polygonscan (for contract verification on Mumbai) ─────────────────────
POLYGONSCAN_API_KEY=YOUR_POLYGONSCAN_API_KEY

# ── Etherscan (for Sepolia verification) ──────────────────────────────────
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# ── Zakat pool ────────────────────────────────────────────────────────────
# Address that receives the 2.5% zakat on every $MIRROR transfer
ZAKAT_POOL_ADDRESS=0xYOUR_ZAKAT_POOL_ADDRESS

# ── $MIRROR initial supply (whole tokens, no decimals) ────────────────────
MIRROR_INITIAL_SUPPLY=1000000

# ── NFT public mint price in MATIC (e.g. 20 = 20 MATIC) ──────────────────
MINT_PRICE_MATIC=20

# ── Staking reward rate (MIRROR per second per staked NFT, in wei) ────────
# Default: 0.001 MIRROR/s = 86.4 MIRROR/day per NFT
STAKING_REWARD_RATE=1000000000000000

# ── Arweave upload ────────────────────────────────────────────────────────
# Path to your Arweave wallet keyfile (JSON)
ARWEAVE_KEY_PATH=./arweave-wallet.json

# ── Mars DAO deployment ───────────────────────────────────────────────────
# Initial $MARS token supply (whole tokens, no decimals)
MARS_INITIAL_SUPPLY=1000000

# Address that receives 2.5% zakat on every $MARS transfer and treasury disbursement
ZAKAT_TREASURY=0xYOUR_ZAKAT_TREASURY_ADDRESS

# Five founding Core Council member addresses
COUNCIL_0=0xCOUNCIL_MEMBER_0
COUNCIL_1=0xCOUNCIL_MEMBER_1
COUNCIL_2=0xCOUNCIL_MEMBER_2
COUNCIL_3=0xCOUNCIL_MEMBER_3
COUNCIL_4=0xCOUNCIL_MEMBER_4

# Already-deployed MirrorToken address (for secondary governance weight)
MIRROR_TOKEN_ADDRESS=0xYOUR_MIRROR_TOKEN_ADDRESS

# Per-vote participation reward in $MARS wei (optional; 0 = disabled)
# Example: 1000000000000000000 = 1 MARS per vote
REWARD_RATE=0

# ── Global Blast (scripts/global-blast.js) ───────────────────────────────────
TWITTER_API_KEY=YOUR_TWITTER_API_KEY
TWITTER_API_SECRET=YOUR_TWITTER_API_SECRET
TWITTER_ACCESS_TOKEN=YOUR_TWITTER_ACCESS_TOKEN
TWITTER_ACCESS_SECRET=YOUR_TWITTER_ACCESS_SECRET
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_IDS=-100123456789,-100987654321
DISCORD_WEBHOOK_URLS=https://discord.com/api/webhooks/YOUR_WEBHOOK_1,https://discord.com/api/webhooks/YOUR_WEBHOOK_2
REDDIT_CLIENT_ID=YOUR_REDDIT_CLIENT_ID
REDDIT_CLIENT_SECRET=YOUR_REDDIT_CLIENT_SECRET
REDDIT_USERNAME=YOUR_REDDIT_USERNAME
REDDIT_PASSWORD=YOUR_REDDIT_PASSWORD
REDDIT_USER_AGENT=VinelandEternal/1.0 by u/YOUR_REDDIT_USERNAME
BLAST_SUBREDDITS=CryptoCurrency,web3,ethereum,defi,polygon
SITE_URL=https://vinelandeternal.vercel.app

# ── CEX Listing (scripts/cex-listing.js) ─────────────────────────────────────
TOKEN_CONTRACT_ADDRESS=0xYOUR_MIRROR_TOKEN_ADDRESS
TOKEN_SYMBOL=MIRROR
TOKEN_NAME=Mirror Token
TOKEN_DECIMALS=18
TOKEN_TOTAL_SUPPLY=1000000000
TOKEN_CHAIN=Polygon
TOKEN_WEBSITE=https://vinelandeternal.vercel.app
TOKEN_WHITEPAPER=https://vinelandeternal.vercel.app/whitepaper.pdf
TOKEN_GITHUB=https://github.com/chaishillomnitech1/VinelandEternal
TEAM_CONTACT_EMAIL=team@vinelandeternal.io
TEAM_TELEGRAM=@vinelandeternal
COINBASE_ASSET_API_KEY=YOUR_COINBASE_LISTING_API_KEY
SENDGRID_API_KEY=YOUR_SENDGRID_API_KEY
SENDGRID_FROM_EMAIL=team@vinelandeternal.io

# ── Vercel Deployment ─────────────────────────────────────────────────────────
# Required to enable auto-deploy via the Deploy Agape CI/CD workflow.
# Generate at https://vercel.com/account/tokens
VERCEL_TOKEN=YOUR_VERCEL_TOKEN
# Find these in your Vercel project settings → General
VERCEL_ORG_ID=YOUR_VERCEL_ORG_ID
VERCEL_PROJECT_ID=YOUR_VERCEL_PROJECT_ID
# Optional: custom domain alias (default: vinelandeternal.vercel.app)
DASHBOARD_URL=https://vinelandeternal.vercel.app


BOT_PRIVATE_KEY=0xYOUR_BOT_WALLET_PRIVATE_KEY
UNISWAP_V3_POOL_ADDRESS=0xYOUR_MIRROR_WMATIC_V3_POOL
UNISWAP_V3_ROUTER=0x68b3465833fb72A70ecDF485E0e4C7bD8665Fc45
MATIC_WMATIC_ADDRESS=0x0d500B1d8E8eF31E21C99d1Db9A6444d3ADf1270
TRADE_AMOUNT_MIRROR=100
ARB_THRESHOLD_PCT=2.0
POLL_INTERVAL_SEC=12
MAX_GAS_GWEI=200
SLIPPAGE_PCT=0.5
